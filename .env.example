# Supabase Local Credentials (Automatically provided when running `supabase start`)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Telegram Bot Token (from BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# AI Model Provider Keys (OpenAI / Groq / Anthropic)
OPENAI_API_KEY=your-openai-api-key

# Apify (for web scraping)
APIFY_API_TOKEN=your-apify-token

# Zynd AI (Multi-Agent System & ZNS)
ZYND_API_KEY=your-zynd-api-key

# Superplane (Workflow & Control Plane)
SUPERPLANE_API_KEY=your-superplane-api-key
